  },
  "parameters": {
    "suffix": {
      "type": "string",
      "defaultValue": "mx01",
      "minLength": 4,
      "maxLength": 4,
      "metadata": {
        "description": "Four-character suffix for resource naming."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "SQL Server administrator login username."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL Server administrator login password."
      }
